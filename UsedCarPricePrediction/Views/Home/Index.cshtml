@using System
@using System.ComponentModel.DataAnnotations
@using System.Reflection
@using Microsoft.AspNetCore.Mvc.Rendering
@using UsedCarPricePrediction.Enums
@model DataModels.Models.PredictionInputs

@{
    ViewBag.Title = "Predict Car Price";
}

<div class="card shadow-lg rounded-4 bg-white">
    <h2 class="mb-3 text-center text-success fw-semibold">Enter Car Details</h2>

    <form id="carForm" asp-action="Result" asp-controller="Home" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

        <div class="form-group-section">
            <div class="form-group-title">
                <i class="bi bi-car-front"></i> Vehicle Identity
            </div>
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="@Model.manufacturer" class="form-label">Manufacturer</label>
                    <select asp-for="@Model.manufacturer" class="form-select select2" required>
                        <option value="">-- Select --</option>
                        @foreach (var man in Enum.GetValues<ManufacturerSelectItem>())
                        {
                            <option value="@man">@man</option>
                        }
                    </select>
                    <span asp-validation-for="@Model.manufacturer" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="model" class="form-label">Model (Select option may be slow)</label>
                    <select asp-for="model" class="form-select select2" required>
                        <option value="">-- Select --</option>
                        @foreach (var modelItem in Enum.GetValues<ModelSelectItem>())
                        {
                            <option value="@modelItem">@modelItem</option>
                        }
                    </select>
                    <span asp-validation-for="model" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="@Model.year" class="form-label">Model Year</label>
                    <input asp-for="@Model.year" class="form-control" type="number" placeholder="2024" required />
                    <span asp-validation-for="@Model.year" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="type" class="form-label">Vehicle Type</label>
                    <select asp-for="type" class="form-select select2" required>
                        <option value="">-- Select --</option>
                        @foreach (var typeItem in Enum.GetValues<TypeSelectItem>())
                        {
                            <option value="@typeItem">@typeItem</option>
                        }
                    </select>
                    <span asp-validation-for="type" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="fuel" class="form-label">Fuel Type</label>
                    <select asp-for="fuel" class="form-select select2" required>
                        <option value="">-- Select --</option>
                        @foreach (var fuelItem in Enum.GetValues<FuelSelectItem>())
                        {
                            <option value="@fuelItem">@fuelItem</option>
                        }
                    </select>
                    <span asp-validation-for="fuel" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="transmission" class="form-label">Transmission</label>
                    <select asp-for="transmission" class="form-select select2" required>
                        <option value="">-- Select --</option>
                        @foreach (var trans in Enum.GetValues<TransmissionSelectItem>())
                        {
                            <option value="@trans">@trans</option>
                        }
                    </select>
                    <span asp-validation-for="transmission" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="form-group-section">
            <div class="form-group-title">
                <i class="bi bi-gear-wide-connected"></i> Technical Specifications
            </div>
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="@Model.odometer" class="form-label">Odometer (mi)</label>
                    <input asp-for="@Model.odometer" class="form-control" type="number" placeholder="45000" required />
                    <span asp-validation-for="@Model.odometer" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="@Model.condition" class="form-label">Overall Condition</label>
                    <select asp-for="@Model.condition" class="form-select select2" required>
                        <option value="">-- Select --</option>
                        @foreach (var condition in Enum.GetValues<ConditionSelectItem>())
                        {
                            <option value="@condition">@condition</option>
                        }
                    </select>
                    <span asp-validation-for="@Model.condition" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="cylinders" class="form-label">Engine Cylinders</label>
                    <select asp-for="cylinders" class="form-select select2" required>
                        <option value="">-- Select --</option>
                        @foreach (var cylinder in Enum.GetValues<CylindersSelectItem>())
                        {
                            <option value="@cylinder">@cylinder</option>
                        }
                    </select>
                    <span asp-validation-for="cylinders" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="drive" class="form-label">Drive Train</label>
                    <select asp-for="drive" class="form-select select2" required>
                        <option value="">-- Select --</option>
                        @foreach (var driveItem in Enum.GetValues<DriveSelectItem>())
                        {
                            <option value="@driveItem">@driveItem</option>
                        }
                    </select>
                    <span asp-validation-for="drive" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="form-group-section">
            <div class="form-group-title">
                <i class="bi bi-geo-alt"></i> Location & Details
            </div>
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="title_status" class="form-label">Title Status</label>
                    <select asp-for="title_status" class="form-select select2" required>
                        <option value="">-- Select --</option>
                        @foreach (var titleStatus in Enum.GetValues<TitleStatusSelectItem>())
                        {
                            <option value="@titleStatus">@titleStatus</option>
                        }
                    </select>
                    <span asp-validation-for="title_status" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Lat" class="form-label">Latitude</label>
                    <input asp-for="Lat" class="form-control" type="number" step="any" placeholder="37.77" />
                    <span asp-validation-for="Lat" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Long" class="form-label">Longitude</label>
                    <input asp-for="Long" class="form-control" type="number" step="any" placeholder="-122.41" />
                    <span asp-validation-for="Long" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <label asp-for="description" class="form-label">Additional Description</label>
                    <textarea asp-for="description" class="form-control" rows="3"
                              style="resize:none; overflow:hidden;" oninput="autoResize(this)"
                              placeholder="Briefly describe any unique features or issues..."></textarea>
                    <span asp-validation-for="description" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="text-center mt-3">
            <button type="submit" class="btn btn-success btn-sm px-4" id="predictBtn">
                <span id="btnText">Predict</span>
                <span id="btnSpinner" class="spinner-border spinner-border-sm ms-2" style="display:none;"></span>
            </button>
        </div>
    </form>
</div>

<div id="loadingOverlay" class="loading-overlay" style="display:none;">
    <div class="loading-content">
        <div class="spinner-border text-success" style="width:3rem; height:3rem;"></div>
        <p class="mt-3 text-success fw-semibold">Predicting car price...</p>
    </div>
</div>

<div class="result-container">
    <div class="result" id="res"></div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const carForm = document.getElementById('carForm');
        const resultContainer = document.getElementById('res');

        carForm.addEventListener('submit', function (e) {
            e.preventDefault();

            resultContainer.innerHTML = '';

            showLoading();

            const formData = new FormData(carForm);

            const formAction = carForm.getAttribute('action') || '/Home/Result';

            fetch(formAction, {
                method: 'POST',
                body: formData,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
                .then(response => {
                    if (!response.ok) {
                        return response.text().then(text => {
                            throw new Error(text || `Server error: ${response.status}`);
                        });
                    }
                    return response.text();
                })
                .then(html => {
                    hideLoading();
                    resultContainer.innerHTML = html;
                    resultContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                })
                .catch(error => {
                    hideLoading();
                    console.error('Error:', error);
                    showError('Prediction Failed', error.message || 'An error occurred while predicting the car price. Please try again.');
                });
        });
    });

    function showLoading() {
        document.getElementById('loadingOverlay').style.display = 'flex';
        document.getElementById('predictBtn').disabled = true;
        document.getElementById('btnText').textContent = 'Predicting...';
        document.getElementById('btnSpinner').style.display = 'inline-block';
    }

    function hideLoading() {
        document.getElementById('loadingOverlay').style.display = 'none';
        document.getElementById('predictBtn').disabled = false;
        document.getElementById('btnText').textContent = 'Predict';
        document.getElementById('btnSpinner').style.display = 'none';
    }

    function autoResize(textarea) {
        textarea.style.height = 'auto';
        textarea.style.height = textarea.scrollHeight + 'px';
    }

    function showError(title, message) {
        const errorOverlay = document.createElement('div');
        errorOverlay.className = 'error-overlay';
        errorOverlay.innerHTML = `
            <div class="error-modal">
                <div class="error-icon">!</div>
                <h3 class="error-title">${title}</h3>
                <p class="error-message">${message}</p>
                <button class="error-button" onclick="this.closest('.error-overlay').remove()">Try Again</button>
            </div>
        `;
        document.body.appendChild(errorOverlay);

        errorOverlay.addEventListener('click', function (e) {
            if (e.target === errorOverlay) errorOverlay.remove();
        });

        const handleEscape = (e) => {
            if (e.key === 'Escape') {
                errorOverlay.remove();
                document.removeEventListener('keydown', handleEscape);
            }
        };
        document.addEventListener('keydown', handleEscape);
    }


</script>